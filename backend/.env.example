# ============ 应用配置 ============
PORT=3000
NODE_ENV=development

# ============ 数据库 ============
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/star_reward?schema=public"

# ============ JWT 配置（三种令牌）============
# 家长登录长效令牌
JWT_SECRET=your-super-secret-key-change-in-production
JWT_PARENT_EXPIRES=7d
# 儿童免登长效令牌
JWT_CHILD_EXPIRES=30d
# 家长敏感操作（PIN 校验后）短效令牌
JWT_PIN_EXPIRES=10m
